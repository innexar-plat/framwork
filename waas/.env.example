# WaaS — env example. Copy to .env and set values. Never commit .env with secrets.

# Database (API)
DATABASE_URL=postgresql+asyncpg://waas:waas@localhost:5432/waas

# JWT (auth)
JWT_SECRET_KEY=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=WaaS API

# CORS (comma-separated or single origin)
# CORS_ORIGINS=http://localhost:3000

# Admin (build-time; used by Next.js)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Tenant integrations (Fernet key for encrypting config). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# Cloudflare DNS (provisioning)
# CF_ZONE_ID=
# CF_API_TOKEN=
# CF_BASE_DOMAIN=waasfl.com
# CF_CNAME_TARGET=

# GitHub template fork (provisioning)
# GIT_TOKEN=
# GIT_TEMPLATE_OWNER=
# GIT_TEMPLATE_REPO=waas-site-template

# SMTP / Email (welcome, notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@waasfl.com
# OPERATOR_EMAIL=

# URLs
# PANEL_BASE_URL=https://app.waasfl.com
# SITE_BASE_DOMAIN=waasfl.com
